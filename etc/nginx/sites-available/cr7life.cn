include /var/lib/cr7/etc/nginx/conf.d/upstreams.conf;

server {
  include /var/lib/cr7/etc/nginx/snippets/cr7.conf;

  server_name cr7life.cn;

  listen 443 ssl;
  include /var/lib/cr7/etc/nginx/snippets/ssl_cert_cr7life_cn.conf;
}

server {
  if ($host = cr7life.cn) {
      return 301 https://$host$request_uri;
  }


  listen 80 ;
  server_name cr7life.cn;
  return 404;
}