<view class="cr7-tab-bar safe-area-bottom" style="padding-bottom: {{safeAreaBottom}}px;">
  <view class="cr7-tab-bar__inner">
    <view
      class="cr7-tab-bar__bubble"
      style="left: {{bubbleLeft}}%;"
    ></view>
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="cr7-tab-bar__item {{index === selected ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <image
        src="{{index === selected ? item.iconActive : item.icon}}"
        class="cr7-tab-bar__icon"
        mode="aspectFit"
      />
      <text
        wx:if="{{index === selected}}"
        class="cr7-tab-bar__text"
      >{{item.text}}</text>
    </view>
  </view>
</view>
